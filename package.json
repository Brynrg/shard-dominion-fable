{
  "name": "speedrungames-game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint:paths": "node scripts/check-relative-paths.mjs",
    "lint": "eslint src --ext .ts",
    "test": "playwright test",
    "test:sim": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:live": "playwright test tests/liveness",
    "simulate": "node scripts/simulate.mjs",
    "deploy:portal": "npm run build && node scripts/deploy-portal.mjs"
  },
  "dependencies": {
    "speedrungames-sdk": "github:Brynrg/speedrungames-sdk#v0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "phaser": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.8"
  }
}
